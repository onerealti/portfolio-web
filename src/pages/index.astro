---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import MetricCard from '../components/MetricCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, METRICS, CONTACT, resolvePath } from '../consts';
import pic from '../assets/pic.png';

// Get featured case studies (up to 3), sorted by date descending
const allStudies = await getCollection('case-studies');
const featured = allStudies
	.filter((s) => s.data.featured)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero / Positioning -->
	<section class="hero" id="hero">
		<div class="hero-intro">
			<img
				src={pic.src}
				alt="Murtaza Ahmed - Backend & Infrastructure Consultant"
				class="avatar"
				loading="eager"
			/>
			<div>
				<h1>Backend & Infrastructure Engineering</h1>
				<p class="subtitle">
					I design, build, and fix distributed systems. Specializing in
					high-throughput APIs, cloud infrastructure, and platform reliability
					for teams that can't afford downtime.
				</p>
			</div>
		</div>
		<div class="hero-cta">
			<a href={resolvePath('/case-studies/')} class="cta-primary" id="cta-case-studies">View Case Studies</a>
			<a href={`mailto:${CONTACT.email}`} class="cta-secondary" id="cta-contact">Get in Touch</a>
		</div>
	</section>

	<!-- Metrics -->
	<section class="metrics-section" id="metrics">
		<h2>By the Numbers</h2>
		<div class="metrics-grid">
			{METRICS.map((m) => <MetricCard value={m.value} label={m.label} />)}
		</div>
	</section>

	<!-- Featured Case Studies -->
	{featured.length > 0 && (
		<section class="featured-section" id="featured">
			<div class="section-header">
				<h2>Featured Work</h2>
				<a href={resolvePath('/case-studies/')} class="view-all" id="view-all-studies">View all case studies &rarr;</a>
			</div>
			<div class="studies-list">
				{featured.map((study) => <CaseStudyCard study={study} />)}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	/* Hero */
	.hero {
		margin-bottom: 3em;
	}

	.hero-intro {
		display: flex;
		align-items: center;
		gap: 1.5em;
		margin-bottom: 1.5em;
	}

	.avatar {
		width: 160px;
		height: 160px;
		min-width: 160px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		border: 3px solid rgb(var(--gray-light));
		box-shadow: 0 4px 12px rgba(var(--gray), 25%);
	}

	.hero h1 {
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: rgb(var(--gray));
		max-width: 55ch;
		margin-bottom: 0;
	}

	@media (max-width: 720px) {
		.hero-intro {
			flex-direction: column;
			align-items: flex-start;
			gap: 1.25em;
		}
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
	}

	.cta-primary,
	.cta-secondary {
		display: inline-block;
		padding: 0.5em 1.5em;
		border-radius: 6px;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		transition: background-color 0.15s ease, color 0.15s ease;
	}

	.cta-primary {
		background-color: rgb(var(--black));
		color: var(--color-bg-base);
	}

	.cta-primary:hover {
		background-color: var(--accent);
		color: var(--color-bg-base);
		text-decoration: none;
	}

	.cta-secondary {
		border: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
		background-color: var(--color-bg-base);
	}

	.cta-secondary:hover {
		border-color: rgb(var(--gray));
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}

	/* Metrics */
	.metrics-section {
		margin-bottom: 3em;
	}

	.metrics-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75em;
	}

	@media (min-width: 720px) {
		.metrics-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	/* Featured */
	.featured-section {
		margin-bottom: 2em;
	}

	.studies-list {
		display: flex;
		flex-direction: column;
		gap: 1em;
		margin-bottom: 1.5em;
	}

	.view-all {
		font-size: 0.875rem;
		color: rgb(var(--gray));
	}

	.view-all:hover {
		color: var(--accent);
	}
</style>
